    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "minio": "^8.0.7",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.6",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.14.0",
