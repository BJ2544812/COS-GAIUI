{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean:vite": "node -e \"const fs=require('fs');const p='node_modules/.vite';if(fs.existsSync(p))fs.rmSync(p,{recursive:true,force:true});console.log('cleared',p);\"",
    "dev:clean": "npm run clean:vite && npm run dev",
    "dev:server": "prisma generate && tsx src/server/index.ts",
    "dev:server:fresh": "node scripts/runtime-cleanup.mjs && prisma generate && tsx src/server/index.ts",
    "dev:server:ci": "prisma migrate deploy && prisma generate && tsx src/server/scripts/seed.ts && tsx src/server/scripts/seed-demo-church-v2.ts && tsx src/server/scripts/seed-demo-roles.ts && tsx src/server/index.ts",
    "runtime:clean": "node scripts/runtime-cleanup.mjs",
    "zero-state:reset": "node scripts/zero-state-reset.mjs",
    "runtime:activate": "node scripts/runtime-activate.mjs",
    "db:migrate": "prisma migrate deploy",
    "dev:prepare": "prisma migrate deploy && prisma generate",
    "postinstall": "prisma generate",
    "build": "vite build",
    "start": "node dist/server/index.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:e2e": "tsx src/server/scripts/test-e2e.ts",
    "db:check": "tsx src/server/scripts/verify-db.ts",
    "seed": "tsx src/server/scripts/seed.ts",
    "seed:demo-roles": "tsx src/server/scripts/seed-demo-roles.ts",
    "seed:demo-church": "tsx src/server/scripts/seed-demo-church-v2.ts",
    "seed:demo-church:reset": "cross-env DEMO_CHURCH_RESET=1 tsx src/server/scripts/seed-demo-church-v2.ts",
    "seed:launch": "npm run seed && npm run seed:demo-church && npm run seed:demo-roles",
    "clean:reset": "tsx src/server/scripts/clean-install-reset.ts",
    "clean:install": "tsx src/server/scripts/clean-install.ts",
    "db:dev-normalize": "tsx src/server/scripts/normalize-dev-dataset.ts",
    "verify:runtime": "tsx src/server/scripts/runtime-boot-verify.ts",
    "verify:go-live": "tsx src/server/scripts/go-live-verify.ts",
    "verify:stabilization": "tsx src/server/scripts/verify-stabilization.ts",
    "stabilization:gate": "npm run verify:v1 && npm run verify:go-live && npm run verify:stabilization",
    "pilot:validate": "tsx src/server/scripts/pilot-validate.ts",
    "simulate:church": "tsx src/server/scripts/operational-scenario-simulation.ts",
    "simulate:hr": "tsx src/server/scripts/hr-operational-simulation.ts",
    "validate:roles": "tsx src/server/scripts/role-walkthrough-validation.ts",
    "audit:hr": "tsx src/server/scripts/hr-capability-audit.ts",
    "test:pilot": "cross-env PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001 playwright test e2e/production-rollout.spec.ts e2e/sunday-operations.spec.ts e2e/zero-state-install.spec.ts e2e/settings-hardening.spec.ts e2e/go-live-hardening.spec.ts e2e/deployment-launch.spec.ts e2e/smoke.spec.ts",
    "verify:release": "tsx src/server/scripts/verify-release.ts",
    "verify:v1": "tsx src/server/scripts/verify-v1.ts",
    "verify:routes": "node scripts/wait-for-health.mjs http://127.0.0.1:4002/health/routes",
    "report:runtime": "tsx src/server/scripts/generate-runtime-report.ts",
    "deploy:production": "node scripts/deploy-production.mjs",
    "backup:tenant": "tsx src/server/scripts/backup-tenant.ts",
    "backup:validate": "tsx src/server/scripts/backup-validate.ts",
    "drill:restore": "tsx src/server/scripts/restore-drill.ts",
    "drill:restore:quick": "cross-env DRILL_SKIP_E2E=1 tsx src/server/scripts/restore-drill.ts",
    "audit:api-paths": "tsx scripts/api-path-audit.ts",
    "uat:cashfree": "tsx src/server/scripts/cashfree-sandbox-uat.ts",
    "test:pw": "cross-env PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001 playwright test",
    "test:pw:ci": "node scripts/write-playwright-ui-port.mjs && cross-env CI=1 playwright test",
    "test:pw:ui": "playwright test --ui",
    "pw:install": "playwright install chromium"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react-big-calendar": "^1.16.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "bullmq": "^5.76.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "minio": "^8.0.7",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.6",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.7",
    "react-is": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "get-port": "^7.2.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
