{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "prisma generate && tsx src/server/index.ts",
    "dev:server:ci": "prisma migrate deploy && prisma generate && tsx src/server/index.ts",
    "db:migrate": "prisma migrate deploy",
    "dev:prepare": "prisma migrate deploy && prisma generate",
    "postinstall": "prisma generate",
    "build": "vite build",
    "start": "node dist/server/index.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:e2e": "tsx src/server/scripts/test-e2e.ts",
    "db:check": "tsx src/server/scripts/verify-db.ts",
    "seed": "tsx src/server/scripts/seed.ts",
    "db:dev-normalize": "tsx src/server/scripts/normalize-dev-dataset.ts",
    "verify:runtime": "tsx src/server/scripts/runtime-boot-verify.ts",
    "test:pw": "node scripts/write-playwright-ui-port.mjs && playwright test",
    "test:pw:ui": "playwright test --ui",
    "pw:install": "playwright install chromium"
  },
  "dependencies": {
