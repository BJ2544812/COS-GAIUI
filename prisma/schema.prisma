  memberId     String?
  userId       String?
  status       String    @default("pending")
  openedAt     DateTime?
  deliveredAt  DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
