model BackupRun {
  id          String    @id @default(uuid())
  tenantId    String
  status      String
  storageKey  String?
  sizeBytes   Int?
  verified    Boolean   @default(false)
  errorDetail String?
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

