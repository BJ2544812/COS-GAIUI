// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// Identity & Multi-Tenancy
// ---------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  roles             Role[]
  members           Member[]
  families          Family[]
  campuses          Campus[]
  ministries        Ministry[]
  events            Event[]
  attendances       Attendance[]
  attendanceSessions AttendanceSession[]
  accounts            Account[]
  vouchers            Voucher[]
  financialReceipts   FinancialReceipt[]
  voucherFySequences  VoucherFySequence[]
  receiptFySequences  ReceiptFySequence[]
  journalEntries      JournalEntry[]
  settings            Setting[]
  careNotes         CareNote[]
  donations         Donation[]
  campaigns         Campaign[]
  vendors           Vendor[]
  payableBills      PayableBill[]
  payablePayments   PayablePayment[]
  bankReconciliationSessions BankReconciliationSession[]
  bankStatementLines BankStatementLine[]
  payrollRuns       PayrollRun[]
  payrollLines      PayrollLine[]
  approvalRules     ApprovalRule[]
  approvalRequests  ApprovalRequest[]
  approvalDecisions ApprovalDecision[]
  exportLogs        ExportLog[]
  yearCloseRuns     YearCloseRun[]
  assetDepreciationEntries AssetDepreciationEntry[]
  assets            Asset[]
  contacts          Contact[]
  communicationLogs CommunicationLog[]
  communicationCampaigns CommunicationCampaign[]
  communicationDeliveries CommunicationDelivery[]
  outreachFollowUps OutreachFollowUp[]
  operationalDigests OperationalDigest[]
  backupRuns BackupRun[]
  documents         Document[]
  pageData          PageData[]
  sermons           Sermon[]
  idempotencyKeys  IdempotencyKey[]
  processedRazorpayEvents ProcessedRazorpayEvent[]
  processedCashfreeEvents ProcessedCashfreeEvent[]
  gatewayPaymentOrders GatewayPaymentOrder[]
  gatewaySettlements GatewaySettlement[]
  serviceCollectionSessions ServiceCollectionSession[]
  eventLogs         EventLog[]
  analyticsEvents   AnalyticsEvent[]
  funds             Fund[]
  costCenters       CostCenter[]
  voucherAttachments VoucherAttachment[]
  financialAuditLogs FinancialAuditLog[]
  financialYears    FinancialYear[]
  budgets           Budget[]
  notifications     Notification[]

  regions           Region[]
  zones             Zone[]
  smallGroups       SmallGroup[]
  smallGroupMembers SmallGroupMember[]
  careCases         CareCase[]
  careLogs          CareLog[]
  prayerRequests    PrayerRequest[]
  pathways          Pathway[]
  pathwaySteps      PathwayStep[]
  memberPathwayProgress MemberPathwayProgress[]
  mentorships       Mentorship[]
  tasks             Task[]
  memberEngagementSnapshots MemberEngagementSnapshot[]
  assetMaintenanceLogs AssetMaintenanceLog[]

  employmentProfiles EmploymentProfile[]
  leaveRequests     LeaveRequest[]
  leaveBalances     LeaveBalance[]
  payrollStructures PayrollStructure[]
  reimbursementRequests ReimbursementRequest[]
  staffDocuments    StaffDocument[]
  performanceReviews PerformanceReview[]
  trainingRecords   TrainingRecord[]
  recruitmentPipelines RecruitmentPipeline[]
  onboardingTasks   OnboardingTask[]
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  email     String
  username  String
  password  String
  roleId    String
  status    String   @default("Active")
  resetToken String?
  resetTokenExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id])

  vouchersApproved Voucher[] @relation("VoucherApprovedBy")
  vouchersPosted  Voucher[] @relation("VoucherPostedBy")
  notifications   Notification[]

  
  memberId          String? @unique
  member            Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  assignedCareCases CareCase[] @relation("AssignedPastor")
  createdCareCases  CareCase[] @relation("CareCaseCreator")
  updatedCareCases  CareCase[] @relation("CareCaseUpdater")
  careLogs          CareLog[]  @relation("CareLogAuthor")
  createdCareLogs   CareLog[]  @relation("CareLogCreator")
  createdPrayerRequests PrayerRequest[] @relation("PrayerRequestCreator")
  assignedTasks     Task[] @relation("AssignedUser")
  createdTasks      Task[] @relation("TaskCreator")
  updatedTasks      Task[] @relation("TaskUpdater")

  @@unique([tenantId, email])
  @@unique([tenantId, username])
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String? // null if system role
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique
  moduleKey   String  @unique
  description String?

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ---------------------------------------------------------
// Core Domain
// ---------------------------------------------------------

model Family {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  imageUrl  String?  // Family/household group photo
  addressLine1 String?
  addressLine2 String?
  city          String?
  stateRegion   String?
  postalCode    String?
  country       String?  @default("India")
  latitude      Float?
  longitude     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members Member[]
}

model Member {
  id             String    @id @default(uuid())
  tenantId       String
  familyId       String?
  name           String
  email          String?
  phone          String?
  role           String?   // e.g., Deacon, Volunteer
  dob            DateTime? // Date of birth
  profileImageUrl String?  // MinIO URL
  membershipDate DateTime?
  status         String    @default("Active")
  growthStage    String    @default("Visitor") // Visitor, Member, Leader
  /// staff | volunteer | pastor | contractor | intern | missionary | ministry_leader
  workforceClass String?
  employmentType String?
  department     String?
  gender         String?   // Male, Female, Other
  aadhaar        String?   // Identity number
  pan            String?   // Identity number
  addressLine1   String?
  addressLine2   String?
  city           String?
  stateRegion    String?
  postalCode     String?
  country        String?   @default("India")
  latitude       Float?
  longitude      Float?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  family Family? @relation(fields: [familyId], references: [id], onDelete: SetNull)

  attendances        Attendance[]
  careNotes          CareNote[]
  donations          Donation[]
  memberDocuments    MemberDocument[]
  spiritualMilestones SpiritualMilestone[]
  memberResponsibilities MemberResponsibility[]

  
  user              User?
  smallGroupMembers SmallGroupMember[]
  careCases         CareCase[] @relation("CareCaseSubject")
  prayerRequests    PrayerRequest[] @relation("PrayerRequester")
  pathwayProgress   MemberPathwayProgress[]
  pathwayMentoring  MemberPathwayProgress[] @relation("AssignedMentor")
  mentees           Mentorship[] @relation("Mentor")
  mentors           Mentorship[] @relation("Disciple")
  assignedTasks     Task[] @relation("AssignedMember")
  engagementSnapshots MemberEngagementSnapshot[]
  assignedAssets    Asset[] @relation("AssetAssignment")
  payrollLines      PayrollLine[]

  reportingManagerId String?
  reportingManager   Member? @relation("ReportingLines", fields: [reportingManagerId], references: [id])
  subordinates       Member[] @relation("ReportingLines")

  employmentProfile EmploymentProfile?
  leaveRequests     LeaveRequest[]
  leaveBalances     LeaveBalance[]
  payrollStructure  PayrollStructure?
  reimbursementRequests ReimbursementRequest[]
  staffDocuments    StaffDocument[]
  reviewsAsReviewee PerformanceReview[] @relation("RevieweeRelation")
  reviewsAsReviewer PerformanceReview[] @relation("ReviewerRelation")
  trainingRecords   TrainingRecord[]
  onboardingTasks   OnboardingTask[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// Member identity documents (Aadhaar, PAN, etc.) — never stored in Member itself
model MemberDocument {
  id         String   @id @default(uuid())
  tenantId   String
  memberId   String
  type       String   // Aadhaar, PAN, BaptismCert, DeclarationForm, Other, GeneratedVisitorDeclaration, GeneratedMemberDeclaration, GeneratedBaptismCertificate
  number     String?  // Document number (masked on read)
  fileUrl    String?  // MinIO URL
  verified   Boolean  @default(false)
  notes      String?
  acceptedAt DateTime? // When the member/staff recorded formal acceptance (declarations)
  signerName String?   // Optional display name captured with acceptance
  signatureDataUrl String? @db.Text // Optional data URL or short placeholder for future e-sign
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([tenantId, type])
}

// Spiritual milestones (Baptism, Salvation date, Small Group, etc.)
model SpiritualMilestone {
  id        String   @id @default(uuid())
  tenantId  String
  memberId  String
  type      String   // Salvation, Baptism, MembershipClass, SmallGroupLeader, Other
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([tenantId, type])
}

// Assignments / Responsibilities (Event fund handling, leadership, volunteer roles)
model MemberResponsibility {
  id              String   @id @default(uuid())
  tenantId        String
  memberId        String
  role            String   // e.g., "Funds Handler", "Small Group Leader", "Usher"
  entityType      String   // e.g., "Event", "Group", "Ministry"
  entityId        String?  // ID of the event/group
  status          String   @default("Active")
  startDate       DateTime @default(now())
  endDate         DateTime?
  allocatedFunds  Float?   // Total funds assigned to them for this role
  usedFunds       Float?   // Funds they have spent
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([tenantId, role])
  @@index([tenantId, status, role])
  @@index([tenantId, entityType, entityId, status, role])
}

model Campus {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  type      String?
  leader    String?
  address   String?
  upiId     String?
  bankInfo  String?
  departments String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ministries Ministry[]
  events     Event[]
  attendanceSessions AttendanceSession[]

  regions Region[]
}

model Ministry {
  id        String   @id @default(uuid())
  tenantId  String
  campusId  String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campus Campus? @relation(fields: [campusId], references: [id], onDelete: SetNull)
}

// ---------------------------------------------------------
// Events & Attendance
// ---------------------------------------------------------

model Event {
  id        String   @id @default(uuid())
  tenantId  String
  campusId  String?
  name      String
  type      String // Service, SmallGroup, Special
  date      DateTime
  /// DRAFT | REVIEW | APPROVED | REGISTRATION_OPEN | REGISTRATION_CLOSED | ACTIVE | COMPLETED | ARCHIVED | CANCELLED
  status         String   @default("DRAFT")
  registrationOpen Boolean  @default(false)
  /// Venue or room label for operational run sheets
  location       String?
  /// Staff-only follow-up / pastoral notes (not public website)
  internalNotes  String?
  /// Optional recurrence hint, e.g. RRULE or `WEEKLY:SUNDAY` — interpreted by clients
  recurringRule  String?
  /// Service/worship run sheet segments (time, item, owner, cues)
  runSheet       Json?
  /// Budget caps, sponsors, registration form config, follow-up flags
  opsConfig      Json?
  cancelledAt    DateTime?
  completedAt    DateTime?
  archivedAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campus Campus? @relation(fields: [campusId], references: [id], onDelete: SetNull)

  attendanceSessions AttendanceSession[]
  donations          Donation[]

  @@index([tenantId, status])
  @@index([tenantId, campusId, date])
}

model AttendanceSession {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  date        DateTime @default(now())
  startTime   DateTime?
  endTime     DateTime?
  status      String   @default("OPEN") // OPEN, CLOSED, ARCHIVED
  type        String   @default("SERVICE") // SERVICE, EVENT, GROUP, VOLUNTEER
  campusId    String?
  eventId     String?
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campus      Campus?  @relation(fields: [campusId], references: [id], onDelete: SetNull)
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  attendances Attendance[]

  @@index([tenantId, date])
  @@index([tenantId, campusId, date])
  @@index([eventId])
}

model Attendance {
  id                String   @id @default(uuid())
  tenantId          String
  sessionId         String
  memberId          String?
  visitorName       String?
  visitorPhone      String?
  status            String   @default("PRESENT") // PRESENT, LATE, EXCUSED, ABSENT
  checkInTime       DateTime @default(now())
  method            String   @default("MANUAL") // MANUAL, KIOSK, MOBILE, QR
  notes             String?

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session           AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member            Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([tenantId, sessionId])
  @@index([memberId])
  @@index([sessionId, checkInTime])
  @@index([tenantId, memberId, checkInTime])
}

// ---------------------------------------------------------
// Accounting & Finance (Indian Context)
// ---------------------------------------------------------

model Account {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  type      String // Asset, Liability, Equity, Revenue, Expense
  parentId  String?
  isActive  Boolean  @default(true)
  balance   Decimal  @default(0) @db.Decimal(18, 2) // Denormalized; updated only in post transaction
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    Account?  @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children  Account[] @relation("AccountHierarchy")

  journalEntries JournalEntry[]
  bankReconciliationSessions BankReconciliationSession[]
  bankStatementLines BankStatementLine[]

  @@unique([tenantId, code])
}

model Fund {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // General, Missions, Building
  type        String   // Restricted, Unrestricted, BoardDesignated
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
  budgets Budget[]
  campaigns Campaign[]
  donations Donation[]
  financialReceipts FinancialReceipt[]
  payableBills PayableBill[]
  payablePayments PayablePayment[]

  @@unique([tenantId, name])
}

model CostCenter {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // Main Campus, Downtown, Youth Ministry
  code        String   // CC-01
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
  budgets Budget[]
  payableBills PayableBill[]
  payablePayments PayablePayment[]
}

model Voucher {
  id          String    @id @default(uuid())
  tenantId    String
  /** Final number (PREFIX-YYYY-#####) assigned on post. Drafts use DRAFT-… until posted. */
  voucherNo   String
  type        String // Receipt, Payment, Journal, Contra, Reversal
  date        DateTime
  amount      Decimal  @db.Decimal(18, 2)
  description String?
  /** draft → approved → posted. Only posted updates account balances. */
  status      String    @default("draft")
  postedAt    DateTime?
  /** Set on a reversal voucher → posted voucher it reverses. UNIQUE enforces at most one reversal per original. */
  reversesVoucherId String? @unique

  approvedByUserId String?
  postedByUserId    String?

  /** donation | manual | reversal | import — traceability, not a workflow gate */
  source      String?
  sourceRefId String?
  /** Canonical source tracking for integrations and immutable provenance. */
  sourceType  String?   // manual, donation, gateway, import, reversal, payroll, reimbursement, etc.
  sourceId    String?
  sourceMetadata Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approvedByUser User? @relation("VoucherApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  postedByUser  User? @relation("VoucherPostedBy", fields: [postedByUserId], references: [id], onDelete: SetNull)

  journalEntries  JournalEntry[]
  attachments     VoucherAttachment[]
  donations       Donation[]
  donationReversals Donation[] @relation("DonationReversalVoucher")
  donationFeeVouchers Donation[] @relation("DonationFeeVoucher")
  donationSettlementVouchers Donation[] @relation("DonationSettlementVoucher")
  financialReceipts FinancialReceipt[]
  payableBills    PayableBill[]
  payablePayments PayablePayment[]
  matchedBankStatementLines BankStatementLine[]
  payrollPayableRuns PayrollRun[] @relation("PayrollPayableVoucher")
  payrollPaymentRuns PayrollRun[] @relation("PayrollPaymentVoucher")
  yearCloseRuns    YearCloseRun[]
  assetDepreciationEntries AssetDepreciationEntry[] @relation("DepreciationVoucher")
  assetDisposals   Asset[] @relation("AssetDisposalVoucher")
  assetCapitalizations Asset[] @relation("AssetCapitalizationVoucher")
  originalVoucher   Voucher?  @relation("VoucherReversal", fields: [reversesVoucherId], references: [id], onDelete: SetNull)
  reversalVoucher  Voucher?  @relation("VoucherReversal")

  @@unique([tenantId, voucherNo])
  @@index([tenantId, status])
  @@index([tenantId, date])
  @@index([tenantId, source])
  @@index([tenantId, sourceType, sourceId])
}

model VoucherAttachment {
  id          String   @id @default(uuid())
  tenantId    String
  voucherId   String
  documentId  String?
  fileUrl     String?
  title       String?
  mimeType    String?
  checksumSha256 String?
  sizeBytes   Int?
  notes       String?
  createdByUserId String?
  createdAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([tenantId, voucherId, createdAt])
}

model FinancialAuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  action      String
  entityType  String
  entityId    String
  actorUserId String?
  beforeJson  Json?
  afterJson   Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, action])
}

/// Per-tenant, per–FY-start-year sequential counter for posted voucher numbers (PREFIX-YYYY-#####).
model VoucherFySequence {
  id          String   @id @default(uuid())
  tenantId    String
  fyStartYear Int
  voucherType String   @default("Journal")
  lastSeq     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, fyStartYear, voucherType])
}

model FinancialYear {
  id        String   @id @default(uuid())
  tenantId  String
  name      String   // e.g. "FY 2026"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  isClosed  Boolean  @default(false)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periods FinancialPeriod[]
  budgets Budget[]
  yearCloseRuns YearCloseRun[]
}

model FinancialPeriod {
  id              String   @id @default(uuid())
  financialYearId String
  name            String   // e.g. "April 2026"
  startDate       DateTime
  endDate         DateTime
  isOpen          Boolean  @default(false)
  isLocked        Boolean  @default(false)

  financialYear FinancialYear @relation(fields: [financialYearId], references: [id], onDelete: Cascade)
}

model Budget {
  id           String   @id @default(uuid())
  tenantId     String
  financialYearId String
  fundId       String?
  costCenterId String?
  amount       Decimal  @db.Decimal(18,2)
  trackingMode String   @default("SOFT") // STRICT, SOFT

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  financialYear FinancialYear @relation(fields: [financialYearId], references: [id], onDelete: Cascade)
  fund          Fund?         @relation(fields: [fundId], references: [id], onDelete: SetNull)
  costCenter    CostCenter?   @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
}

/// Gateway / payment idempotency: one row per (tenant, key, operation); resultRefId stores JSON { voucherId, donationId }.
model IdempotencyKey {
  id          String   @id @default(uuid())
  tenantId    String
  key         String
  operation   String
  resultRefId String
  createdAt   DateTime @default(now())
  /** Expired rows are deleted by cleanup job; not returned by findValid. */
  expiresAt   DateTime

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key, operation])
  @@index([tenantId, createdAt])
  @@index([expiresAt])
}

/// Razorpay webhook `id` (evt_…) — prevents replay after successful handling.
model ProcessedRazorpayEvent {
  id            String   @id @default(uuid())
  tenantId      String
  eventId      String
  paymentId     String?
  /** sha256 hex of raw body for audit */
  signatureHash String?
  donationId    String?
  voucherId     String?
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, eventId])
  @@index([tenantId, createdAt])
}

/// Cashfree webhook event id — prevents replay after successful handling.
model ProcessedCashfreeEvent {
  id            String   @id @default(uuid())
  tenantId      String
  eventId       String
  eventType     String?
  orderId       String?
  paymentId     String?
  signatureHash String?
  donationId    String?
  voucherId     String?
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, eventId])
  @@index([tenantId, createdAt])
}

model JournalEntry {
  id        String   @id @default(uuid())
  tenantId  String
  voucherId String
  accountId String
  debit     Decimal  @default(0) @db.Decimal(18, 2)
  credit    Decimal  @default(0) @db.Decimal(18, 2)
  narration String?
  fundId       String?
  costCenterId String?
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)
  fund       Fund?       @relation(fields: [fundId], references: [id], onDelete: Restrict)
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
}

// ---------------------------------------------------------
// Settings
// ---------------------------------------------------------

model Setting {
  id       String @id @default(uuid())
  tenantId String
  key      String
  value    String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

// ---------------------------------------------------------
// Discipleship & Pastoral Care
// ---------------------------------------------------------

model CareNote {
  id        String   @id @default(uuid())
  tenantId  String
  memberId  String
  authorId  String
  note      String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // author User   @relation(fields: [authorId], references: [id], onDelete: SetNull) // Optional relation if we want strict FK
}

// ---------------------------------------------------------
// Giving & Donations
// ---------------------------------------------------------

model Campaign {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  goal      Float?
  startDate DateTime?
  endDate   DateTime?
  defaultFundId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultFund Fund?    @relation(fields: [defaultFundId], references: [id], onDelete: SetNull)
  donations Donation[]
  financialReceipts FinancialReceipt[]
}

model Donation {
  id         String   @id @default(uuid())
  tenantId   String
  donorId    String?
  campaignId String?
  fundId     String?
  eventId    String?
  voucherId  String?
  reversalVoucherId String?
  feeVoucherId String?
  settlementVoucherId String?
  gatewayPaymentOrderId String?
  gatewaySettlementId String?
  serviceCollectionSessionId String?
  amount     Decimal  @db.Decimal(18, 2)
  /** Amount charged at gateway (may include donor-covered fee). */
  grossAmount Decimal? @db.Decimal(18, 2)
  netSettlementAmount Decimal? @db.Decimal(18, 2)
  gatewayFeeAmount Decimal? @db.Decimal(18, 2)
  donorCoveredFee Decimal? @db.Decimal(18, 2)
  date       DateTime @default(now())
  method     String // Cash, Card, UPI, ONLINE, etc.
  reference  String?
  donationCategory String?
  isAnonymous Boolean @default(false)
  /** e.g. user | gateway | cashfree_webhook */
  source     String?
  sourceRefId String?
  gateway     String?
  gatewayOrderId String?
  gatewayPaymentId String?
  settlementStatus String @default("n_a")
  reconciliationState String @default("unmatched")
  notes      String?
  status     String   @default("Recorded")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  donor    Member?   @relation(fields: [donorId], references: [id], onDelete: SetNull)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  fund     Fund?     @relation(fields: [fundId], references: [id], onDelete: SetNull)
  event    Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  voucher  Voucher?  @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  reversalVoucher Voucher? @relation("DonationReversalVoucher", fields: [reversalVoucherId], references: [id], onDelete: SetNull)
  feeVoucher Voucher? @relation("DonationFeeVoucher", fields: [feeVoucherId], references: [id], onDelete: SetNull)
  settlementVoucher Voucher? @relation("DonationSettlementVoucher", fields: [settlementVoucherId], references: [id], onDelete: SetNull)
  gatewayPaymentOrder GatewayPaymentOrder? @relation(fields: [gatewayPaymentOrderId], references: [id], onDelete: SetNull)
  gatewaySettlement GatewaySettlement? @relation(fields: [gatewaySettlementId], references: [id], onDelete: SetNull)
  serviceCollectionSession ServiceCollectionSession? @relation(fields: [serviceCollectionSessionId], references: [id], onDelete: SetNull)
  receipt  FinancialReceipt?
  settlementLines GatewaySettlementLine[]

  @@index([tenantId, date])
  @@index([tenantId, fundId, date])
  @@index([tenantId, voucherId])
  @@index([tenantId, reversalVoucherId])
  @@index([tenantId, settlementStatus])
  @@index([tenantId, gatewaySettlementId])
  @@index([tenantId, serviceCollectionSessionId])
  @@unique([tenantId, gatewayPaymentId])
}

/// Pending/completed gateway checkout order (Cashfree/Razorpay).
model GatewayPaymentOrder {
  id              String   @id @default(uuid())
  tenantId        String
  gateway         String
  externalOrderId String
  status          String   @default("created")
  donationAmount  Decimal  @db.Decimal(18, 2)
  grossAmount     Decimal  @db.Decimal(18, 2)
  gatewayFeeAmount Decimal @default(0) @db.Decimal(18, 2)
  donorCoveredFee Boolean  @default(false)
  currency        String   @default("INR")
  donorName       String?
  donorPhone      String?
  donorEmail      String?
  donorId         String?
  donationCategory String?
  fundId          String?
  campaignId      String?
  eventId         String?
  serviceCollectionSessionId String?
  isAnonymous     Boolean  @default(false)
  metadataJson    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  donations Donation[]

  @@unique([tenantId, gateway, externalOrderId])
  @@index([tenantId, status])
}

/// Cashfree (or gateway) settlement batch imported for reconciliation.
model GatewaySettlement {
  id                String   @id @default(uuid())
  tenantId          String
  gateway           String
  externalSettlementId String
  settlementDate    DateTime
  grossAmount       Decimal  @db.Decimal(18, 2)
  feeAmount         Decimal  @default(0) @db.Decimal(18, 2)
  netAmount         Decimal  @db.Decimal(18, 2)
  bankReference     String?
  status            String   @default("imported")
  settlementVoucherId String?
  feeVoucherId      String?
  importedAt        DateTime @default(now())
  reconciledAt      DateTime?
  notes             String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines  GatewaySettlementLine[]
  donations Donation[]

  @@unique([tenantId, gateway, externalSettlementId])
  @@index([tenantId, settlementDate])
}

model GatewaySettlementLine {
  id           String   @id @default(uuid())
  tenantId     String
  settlementId String
  donationId   String?
  externalPaymentId String?
  amount       Decimal  @db.Decimal(18, 2)
  feeAmount    Decimal  @default(0) @db.Decimal(18, 2)
  matchStatus  String   @default("unmatched")

  settlement GatewaySettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  donation   Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)

  @@index([tenantId, settlementId])
  @@index([donationId])
}

/// Sunday / service offering collection window (e.g. 9AM service).
model ServiceCollectionSession {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  serviceDate DateTime
  status      String   @default("open")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  donations Donation[]

  @@index([tenantId, serviceDate])
}

model Vendor {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  category     String?
  contactName  String?
  email        String?
  phone        String?
  gstin        String?
  pan          String?
  address      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bills        PayableBill[]
  payments     PayablePayment[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model PayableBill {
  id              String   @id @default(uuid())
  tenantId        String
  vendorId        String
  billNo          String
  billDate        DateTime
  dueDate         DateTime?
  amount          Decimal  @db.Decimal(18, 2)
  outstanding     Decimal  @db.Decimal(18, 2)
  expenseAccountId String
  payableAccountId String
  fundId          String?
  costCenterId    String?
  status          String   @default("Pending") // Pending, PartiallyPaid, Paid, Cancelled
  description     String?
  sourceType      String?  // vendor_bill, import
  sourceId        String?
  sourceMetadata  Json?
  billVoucherId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  fund            Fund?    @relation(fields: [fundId], references: [id], onDelete: SetNull)
  costCenter      CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  billVoucher     Voucher? @relation(fields: [billVoucherId], references: [id], onDelete: SetNull)
  payments        PayablePayment[]

  @@unique([tenantId, billNo])
  @@index([tenantId, vendorId, status])
}

model PayablePayment {
  id               String   @id @default(uuid())
  tenantId         String
  vendorId         String
  billId           String
  paymentDate      DateTime
  amount           Decimal  @db.Decimal(18, 2)
  paymentAccountId String
  payableAccountId String
  fundId           String?
  costCenterId     String?
  notes            String?
  sourceType       String?  // vendor_payment, import
  sourceId         String?
  paymentVoucherId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor           Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  bill             PayableBill @relation(fields: [billId], references: [id], onDelete: Restrict)
  fund             Fund?    @relation(fields: [fundId], references: [id], onDelete: SetNull)
  costCenter       CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  paymentVoucher   Voucher? @relation(fields: [paymentVoucherId], references: [id], onDelete: SetNull)

  @@index([tenantId, vendorId, paymentDate])
  @@index([tenantId, billId])
}

model FinancialReceipt {
  id          String   @id @default(uuid())
  tenantId    String
  receiptNo   String
  donationId  String   @unique
  voucherId   String?
  issueDate   DateTime @default(now())
  amount      Decimal  @db.Decimal(18, 2)
  donorName   String
  donorEmail  String?
  donorPhone  String?
  fundId      String?
  campaignId  String?
  eightyGEligible Boolean @default(false)
  pdfUrl      String?
  pdfChecksumSha256 String?
  regeneratedCount Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  donation  Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  voucher   Voucher? @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  fund      Fund?    @relation(fields: [fundId], references: [id], onDelete: SetNull)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([tenantId, receiptNo])
  @@index([tenantId, issueDate])
}

model ReceiptFySequence {
  id          String   @id @default(uuid())
  tenantId    String
  fyStartYear Int
  lastSeq     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, fyStartYear])
}

model BankReconciliationSession {
  id          String   @id @default(uuid())
  tenantId    String
  accountId   String
  fromDate    DateTime
  toDate      DateTime
  status      String   @default("Open") // Open, Closed
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  statementLines BankStatementLine[]

  @@index([tenantId, accountId, fromDate, toDate])
}

model BankStatementLine {
  id                String   @id @default(uuid())
  tenantId          String
  sessionId         String
  accountId         String
  txnDate           DateTime
  amount            Decimal  @db.Decimal(18, 2)
  direction         String   // Debit | Credit
  reference         String?
  description       String?
  isMatched         Boolean  @default(false)
  matchedVoucherId  String?
  matchedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session           BankReconciliationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  account           Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  matchedVoucher    Voucher? @relation(fields: [matchedVoucherId], references: [id], onDelete: SetNull)

  @@index([tenantId, sessionId, txnDate])
  @@index([tenantId, accountId, isMatched])
}

model PayrollRun {
  id              String   @id @default(uuid())
  tenantId        String
  periodYear      Int
  periodMonth     Int
  status          String   @default("Draft") // Draft, Posted, Closed
  totalGross      Decimal  @db.Decimal(18,2) @default(0)
  totalDeductions Decimal  @db.Decimal(18,2) @default(0)
  totalNet        Decimal  @db.Decimal(18,2) @default(0)
  payableVoucherId String?
  paymentVoucherId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payableVoucher  Voucher? @relation("PayrollPayableVoucher", fields: [payableVoucherId], references: [id], onDelete: SetNull)
  paymentVoucher  Voucher? @relation("PayrollPaymentVoucher", fields: [paymentVoucherId], references: [id], onDelete: SetNull)
  lines           PayrollLine[]

  @@unique([tenantId, periodYear, periodMonth])
  @@index([tenantId, status])
}

model PayrollLine {
  id                  String   @id @default(uuid())
  tenantId            String
  runId               String
  memberId            String
  grossAmount         Decimal  @db.Decimal(18,2)
  deductionAmount     Decimal  @db.Decimal(18,2) @default(0)
  netAmount           Decimal  @db.Decimal(18,2)
  salaryExpenseAccountId String
  payrollPayableAccountId String
  payslipNo           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  run                 PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  member              Member   @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([tenantId, runId])
  @@index([tenantId, memberId])
}

model ApprovalRule {
  id          String   @id @default(uuid())
  tenantId    String
  entityType  String   // Voucher, PayrollRun
  minAmount   Decimal? @db.Decimal(18,2)
  moduleKey   String?
  approverRoleId String?
  level       Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityType, isActive])
}

model ApprovalRequest {
  id            String   @id @default(uuid())
  tenantId      String
  entityType    String
  entityId      String
  requestedByUserId String?
  status        String   @default("Pending") // Pending, Approved, Rejected
  currentLevel  Int      @default(1)
  minRequiredLevel Int   @default(1)
  amount        Decimal? @db.Decimal(18,2)
  moduleKey     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  decisions     ApprovalDecision[]

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, status, currentLevel])
}

model ApprovalDecision {
  id            String   @id @default(uuid())
  tenantId      String
  approvalRequestId String
  level         Int
  decision      String   // Approved, Rejected
  actorUserId   String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@index([tenantId, approvalRequestId, level])
}

model ExportLog {
  id            String   @id @default(uuid())
  tenantId      String
  exportType    String
  filtersJson   Json?
  rowCount      Int?
  checksumSha256 String?
  generatedByUserId String?
  generatedAt   DateTime @default(now())
  sourceEntityType String?
  sourceEntityId String?

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([tenantId, exportType, generatedAt])
}

model YearCloseRun {
  id            String   @id @default(uuid())
  tenantId      String
  financialYearId String
  status        String   @default("Completed")
  closingVoucherId String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  financialYear FinancialYear @relation(fields: [financialYearId], references: [id], onDelete: Cascade)
  closingVoucher Voucher? @relation(fields: [closingVoucherId], references: [id], onDelete: SetNull)

  @@index([tenantId, financialYearId, createdAt])
}

// ---------------------------------------------------------
// Assets & Facilities
// ---------------------------------------------------------

model Asset {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  category     String?
  serialNumber String?
  location     String?   // Physical location / station
  value        Float
  purchaseDate DateTime?
  status       String    @default("Active") // Active, Maintenance, Damaged, Retired, Archived
  condition    String?   // Good, Fair, Poor
  imageUrl     String?
  notes        String?
  assignedToId String?   // Member ID if assigned
  capitalizationVoucherId String?
  disposalVoucherId String?
  residualValue Float?   @default(0)
  usefulLifeMonths Int?  @default(60)
  depreciationMethod String? @default("SLM") // SLM
  accumulatedDepreciation Float @default(0)
  lastDepreciationDate DateTime?
  disposedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo Member? @relation("AssetAssignment", fields: [assignedToId], references: [id], onDelete: SetNull)
  capitalizationVoucher Voucher? @relation("AssetCapitalizationVoucher", fields: [capitalizationVoucherId], references: [id], onDelete: SetNull)
  disposalVoucher Voucher? @relation("AssetDisposalVoucher", fields: [disposalVoucherId], references: [id], onDelete: SetNull)

  maintenanceLogs AssetMaintenanceLog[]
  depreciationEntries AssetDepreciationEntry[]
}

model AssetMaintenanceLog {
  id          String   @id @default(uuid())
  tenantId    String
  assetId     String
  serviceType String   // Routine, Emergency, Upgrade, Inspection
  description String
  scheduledAt DateTime?
  completedAt DateTime?
  cost        Float?
  technician  String?
  status      String   @default("Scheduled") // Scheduled, InProgress, Completed, Cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset  Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId, assetId])
}

model AssetDepreciationEntry {
  id          String   @id @default(uuid())
  tenantId    String
  assetId     String
  periodDate  DateTime
  amount      Decimal  @db.Decimal(18, 2)
  accumulatedAfter Decimal @db.Decimal(18, 2)
  voucherId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  voucher     Voucher? @relation("DepreciationVoucher", fields: [voucherId], references: [id], onDelete: SetNull)

  @@index([tenantId, assetId, periodDate])
}

// ---------------------------------------------------------
// Outreach & Missions
// ---------------------------------------------------------

model Contact {
  id              String    @id @default(uuid())
  tenantId        String
